    "/api/bsc/delete-addresses": {
      "post": {
        "summary": "删除 BSC 监控地址",
        "description": "支持单个/批量删除 BSC 监控地址（软删除）。支持 API Key 调用或后台登录态调用。",
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BSCDeleteAddressesRequest"
              },
              "examples": {
                "single": {
                  "summary": "单个地址",
                  "value": {
                    "address": "0x1111111111111111111111111111111111111111"
                  }
                },
                "batch": {
                  "summary": "批量地址",
                  "value": {
                    "addresses": [
                      "0x1111111111111111111111111111111111111111",
                      "0x2222222222222222222222222222222222222222"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BSCDeleteAddressesResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求体错误或没有有效地址"
          },
          "401": {
            "description": "未登录"
          },
          "500": {
            "description": "服务端错误"
          }
        }
      }
    },
    "/api/tron/balances": {
      "get": {
        "summary": "Tron 余额列表",
        "description": "按分页列出 Tron 监控地址余额（TRX/USDT）。",
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "按地址查询（可选，传入时返回单条记录）"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "usdt_desc/usdt_asc/trx_desc/trx_asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListBalancesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/bsc/balances": {
      "get": {
        "summary": "BSC 余额列表",
        "description": "按分页列出 BSC 监控地址余额（BNB/USDT）。",
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "address",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "按地址查询（可选，传入时返回单条记录）"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "usdt_desc/usdt_asc/bnb_desc/bnb_asc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListBalancesResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/tron/transfers/in": {
      "get": {
        "summary": "Tron 转入流水",
        "description": "查询指定监控地址的转入流水（来自 transfer_in_records）。",
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "watch_address",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "asset_code",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "TRX/USDT（可选）"
            }
          },
          {
            "name": "start_time",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "起始时间（毫秒时间戳或 RFC3339，可选）"
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "结束时间（毫秒时间戳或 RFC3339，可选）"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 20
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListTransfersResponse"
                }
              }
            }
          }
        }
      }
    },
