            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "asset_code",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "BNB/USDT（可选）"
            }
          },
          {
            "name": "start_time",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "起始时间（毫秒时间戳或 RFC3339，可选）"
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "结束时间（毫秒时间戳或 RFC3339，可选）"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
