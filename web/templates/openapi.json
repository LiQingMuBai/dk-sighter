{
  "openapi": "3.0.3",
  "info": {
    "title": "Tron Watcher API",
    "description": "Tron + BSC 监控服务对外接口文档（同库同站点）。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "{{ .HTTPURL }}"
    },
    {
      "url": "{{ .HTTPSURL }}"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      },
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "AddWatchAddressesRequest": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "description": "单个 Tron 地址，T 开头"
          },
          "addresses": {
            "type": "array",
            "description": "批量 Tron 地址列表，T 开头",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "AddWatchAddressesResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "duplicate_addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "invalid_addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "DeleteTronWatchAddressesRequest": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "description": "单个 Tron 地址，T 开头"
          },
          "addresses": {
            "type": "array",
            "description": "批量 Tron 地址列表，T 开头",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "DeleteTronWatchAddressesResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "total_count": {
            "type": "integer"
          },
          "success_count": {
            "type": "integer"
          },
          "failed_count": {
            "type": "integer"
          },
          "failed_addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "BSCAddWatchAddressesRequest": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "description": "单个 BSC 地址（0x...）"
          },
          "addresses": {
            "type": "array",
            "description": "批量 BSC 地址列表（0x...）",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "BSCAddWatchAddressesResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "count": {
            "type": "integer"
          },
          "addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "duplicate_addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "invalid_addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "BSCDeleteAddressesRequest": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string",
            "description": "单个 BSC 地址（0x...）"
          },
          "addresses": {
            "type": "array",
            "description": "批量 BSC 地址列表（0x...）",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "BSCDeleteAddressesResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "count": {
            "type": "integer",
            "description": "本次实际删除（软删除）数量"
          },
          "addresses": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "deleted_count": {
            "type": "integer",
            "description": "兼容字段，等同 count"
          }
        }
      },
      "BalanceRecord": {
        "type": "object",
        "properties": {
          "address": {
            "type": "string"
          },
          "trx": {
            "type": "string"
          },
          "bnb": {
            "type": "string"
          },
          "usdt": {
            "type": "string"
          },
          "updated_at": {
            "type": "string",
            "description": "RFC3339 时间"
          }
        }
      },
      "ListBalancesResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "total_count": {
            "type": "integer"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BalanceRecord"
            }
          }
        }
      },
      "TransferRecord": {
        "type": "object",
        "properties": {
          "tx_hash": {
            "type": "string"
          },
          "block_number": {
            "type": "integer"
          },
          "block_time": {
            "type": "integer",
            "description": "区块时间戳（毫秒）"
          },
          "asset_code": {
            "type": "string"
          },
          "contract_address": {
            "type": "string"
          },
          "watch_address": {
            "type": "string",
            "description": "命中监控的地址（同一笔转账可能对不同监控地址分别产出记录）"
          },
          "from_address": {
            "type": "string"
          },
          "to_address": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          },
          "log_index": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "description": "RFC3339 时间"
          }
        }
      },
      "ListTransfersResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "total_count": {
            "type": "integer"
          },
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TransferRecord"
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/watch-addresses": {
      "post": {
        "summary": "新增监控地址",
        "description": "支持单个或批量新增 Tron 监控地址。写入成功后会立即刷新内存地址缓存。",
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddWatchAddressesRequest"
              },
              "examples": {
                "single": {
                  "summary": "单个地址",
                  "value": {
                    "address": "TXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
                  }
                },
                "batch": {
                  "summary": "批量地址",
                  "value": {
                    "addresses": [
                      "TXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
                      "TYYYYYYYYYYYYYYYYYYYYYYYYYYYYYYY"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "写入成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddWatchAddressesResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求体错误或没有有效地址"
          },
          "401": {
            "description": "未授权"
          },
          "500": {
            "description": "服务端错误"
          }
        }
      }
    },
    "/api/tron/watch-addresses": {
      "post": {
        "summary": "新增 Tron 监控地址",
        "description": "支持单个或批量新增 Tron 监控地址。写入成功后会立即刷新内存地址缓存。",
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddWatchAddressesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "写入成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AddWatchAddressesResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求体错误或没有有效地址"
          },
          "401": {
            "description": "未授权"
          },
          "500": {
            "description": "服务端错误"
          }
        }
      }
    },
    "/api/tron/delete-addresses": {
      "post": {
        "summary": "删除 Tron 监控地址",
        "description": "支持单个/批量删除 Tron 监控地址（软删除）。支持 API Key 调用或后台登录态调用。",
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DeleteTronWatchAddressesRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DeleteTronWatchAddressesResponse"
                }
              }
            }
          },
          "400": {
            "description": "请求体错误或没有有效地址"
          },
          "401": {
            "description": "未授权"
          },
          "500": {
            "description": "服务端错误"
          }
        }
      }
    },
    "/api/bsc/watch-addresses": {
      "post": {
        "summary": "新增 BSC 监控地址",
        "description": "支持单个或批量新增 BSC 监控地址。",
        "security": [
          {
            "ApiKeyAuth": []
          },
          {
            "BearerAuth": []
